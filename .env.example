# Database (Supabase Postgres)
DATABASE_URL=
DIRECT_URL=

# NextAuth + Google login
AUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase service-role for invoking Edge Functions (e.g. Telegram notifier)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud Storage (artist images / videos)
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Meta (Facebook + Instagram) Webhook ───────────────────────────────────────
# App-level secrets from developers.facebook.com → My Apps → <App> → Settings → Basic
META_APP_ID=
META_APP_SECRET=
# Random string you choose. Configure the same value in the Meta dashboard
# under Webhooks → Page / Instagram → Verify Token.
META_WEBHOOK_VERIFY_TOKEN=

# Initial seed data for El As de la Sierra. Used by scripts/setup-meta-webhooks.ts
# to subscribe the page. Per-artist tokens are stored in the Artist row
# (Artist.metaPageToken) so multiple artists can be added later via DB updates.
EL_AS_PAGE_ID=560288020819289
EL_AS_IG_ID=17841447820142294
EL_AS_PAGE_TOKEN=
