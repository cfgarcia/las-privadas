// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
}

enum Role {
  USER
  ADMIN
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Artist {
  id              String         @id @default(cuid())
  name            String
  slug            String?        @unique // short handle for public /e/[slug] page
  tagline         String?
  description     String
  albumCount      Int?
  careerYears     Int?
  imageUrl        String?
  hoverVideoUrl   String? // Canvas-style video (MP4)
  order           Int            @default(0)
  bookingImageUrl String?
  availabilities  Availability[]
  bookings        Booking[]
  songs           Song[]
  events          Event[]

  // Meta (Facebook + Instagram) integration for real-time DM webhook
  metaPageId    String?       @unique // FB page_id (e.g. "560288020819289" for El As)
  metaIgId      String?       @unique // IG ig_user_id (e.g. "17841447820142294")
  metaPageToken String? // long-lived Page Access Token
  metaInquiries MetaInquiry[]
}

model Song {
  id        String   @id @default(cuid())
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title     String
  mp3Url    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([artistId, order])
}

// A public upcoming show listed on the artist's /e/[slug] ticket page.
// "Boletos" buttons route through /go/[eventId] to count clicks before
// redirecting to ticketUrl (Ticketón etc.).
model Event {
  id          String   @id @default(cuid())
  artistId    String
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title       String? // optional headline; venue is the fallback
  date        DateTime // calendar date of the show, stored as midnight UTC
  venue       String
  city        String
  state       String?
  ticketUrl   String
  flyerUrl    String?
  clickCount  Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([artistId, date])
}

model Availability {
  id          String   @id @default(cuid())
  date        DateTime
  isAvailable Boolean  @default(true)
  artistId    String
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, date])
}

model Booking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id])

  // Booking Details
  date        DateTime
  hours       Int
  city        String
  state       String
  clientName  String
  clientEmail String?
  cellphone   String
  hasWhatsapp Boolean  @default(false)

  // New Fields
  bookingType String? @default("personal") // "personal" or "business"
  venue       String? // Venue name if business

  status String @default("PENDING") // PENDING, CONFIRMED, REJECTED

  metaInquiry MetaInquiry?
}

// A direct message received from Instagram or Facebook Messenger.
// Created by /api/webhooks/meta and reviewed via /admin/inbox.
model MetaInquiry {
  id               String    @id @default(cuid())
  platform         String // "messenger" | "instagram"
  artistId         String?
  artist           Artist?   @relation(fields: [artistId], references: [id])
  pageId           String // FB page_id or IG ig_user_id that received the DM
  conversationId   String? // optional thread ID for deeplink
  senderPsid       String // PSID (FB) or IGSID (IG) — used for API replies
  senderUsername   String?
  senderName       String?
  messageId        String    @unique // Meta's mid — idempotency key
  messageText      String
  receivedAt       DateTime
  intent           String // "saludo" | "booking_general" | "booking_corrido" | "other"
  intentStrength   String // "strong" | "weak"
  status           String    @default("pending") // pending | replied_api | replied_manual | skipped | ignored
  repliedAt        DateTime?
  replyText        String?
  createdBookingId String?   @unique
  createdBooking   Booking?  @relation(fields: [createdBookingId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, receivedAt])
  @@index([artistId, status, intent])
}
