# Copy to `.env.test` to run E2E / integration against a THROWAWAY local database.
# NEVER point this at production Supabase. Unit + integration tests mock the DB
# and do not need any of these — this is only for the Playwright E2E flow when
# you want to run it locally against a real (disposable) Postgres.
#
#   docker run --rm -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=privada_test -p 5432:5432 postgres:16
#   npx prisma migrate deploy && npx prisma db seed
#   npm run test:e2e

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/privada_test?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/privada_test?schema=public"
AUTH_SECRET="test-secret-not-for-production"
NEXTAUTH_URL="http://localhost:3000"

# The guest home flow the E2E covers does NOT need Supabase / Google / GCS / Meta
# creds. Leave these blank unless you extend E2E into authenticated/admin flows.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
